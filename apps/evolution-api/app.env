APP_SLUG="evolution-api"
APP_LABEL="Evolution API"
APP_DESCRIPTION="API de WhatsApp (Evolution) com PostgreSQL padrão e Redis próprio na stack."
APP_CATEGORY="mensageria"
APP_IMAGE_REPO="evoapicloud/evolution-api"
APP_TESTED_TAGS="latest"
APP_DOMAINS="APP_DOMAIN:Domínio da Evolution API, ex: evolution.seudominio.com.br"
APP_SECRETS="EVOLUTION_API_KEY:hex16"
APP_INPUTS=""
APP_NEEDS_POSTGRES="true"
APP_NEEDS_REDIS="true"
APP_SUMMARY_LINES="URL: https://__APP_DOMAIN__;API key (header apikey): __EVOLUTION_API_KEY__;Banco: __POSTGRES_DATABASE__ (no PostgreSQL padrão)"
