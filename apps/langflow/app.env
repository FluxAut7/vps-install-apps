APP_SLUG="langflow"
APP_LABEL="Langflow"
APP_DESCRIPTION="Construtor visual de fluxos e agentes com LLMs."
APP_CATEGORY="ia"
APP_IMAGE_REPO="langflowai/langflow"
APP_TESTED_TAGS="latest"
APP_DOMAINS="APP_DOMAIN:Domínio do Langflow, ex: langflow.seudominio.com.br"
APP_SECRETS="LANGFLOW_SUPERUSER_PASSWORD:hex16;LANGFLOW_SECRET_KEY:hex32"
APP_INPUTS="LANGFLOW_SUPERUSER:Usuário admin do Langflow:admin"
APP_NEEDS_POSTGRES="true"
APP_NEEDS_REDIS="false"
APP_SUMMARY_LINES="URL: https://__APP_DOMAIN__;Usuário: __LANGFLOW_SUPERUSER__;Senha: __LANGFLOW_SUPERUSER_PASSWORD__;Banco: __POSTGRES_DATABASE__ (no PostgreSQL padrão)"
