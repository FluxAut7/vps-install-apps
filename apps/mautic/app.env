APP_SLUG="mautic"
APP_LABEL="Mautic"
APP_DESCRIPTION="Automação de marketing (e-mail, campanhas, landing pages). Inclui MySQL próprio."
APP_CATEGORY="marketing"
APP_IMAGE_REPO="mautic/mautic"
APP_TESTED_TAGS="5-apache"
APP_DOMAINS="APP_DOMAIN:Domínio do Mautic, ex: mautic.seudominio.com.br"
APP_SECRETS="MYSQL_ROOT_PASSWORD:hex16;MAUTIC_ADMIN_PASSWORD:hex16"
APP_INPUTS="MAUTIC_ADMIN_EMAIL:E-mail do admin do Mautic:admin@seudominio.com.br;MAUTIC_ADMIN_USERNAME:Usuário admin do Mautic:admin"
APP_NEEDS_POSTGRES="false"
APP_NEEDS_REDIS="false"
APP_SUMMARY_LINES="URL: https://__APP_DOMAIN__;Usuário: __MAUTIC_ADMIN_USERNAME__;Senha: __MAUTIC_ADMIN_PASSWORD__;E-mail admin: __MAUTIC_ADMIN_EMAIL__;MySQL interno: __STACK_NAME___mysql (root / __MYSQL_ROOT_PASSWORD__)"
