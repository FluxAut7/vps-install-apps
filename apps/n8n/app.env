APP_SLUG="n8n"
APP_LABEL="n8n"
APP_DESCRIPTION="Automação de fluxos (editor, webhook, worker e runners) com PostgreSQL padrão e Redis próprio."
APP_CATEGORY="automacao"
APP_IMAGE_REPO="n8nio/n8n"
APP_TESTED_TAGS="2.11.3"
APP_DOMAINS="APP_DOMAIN:Domínio do editor n8n, ex: n8n.seudominio.com.br;WEBHOOK_DOMAIN:Domínio dos webhooks n8n (pode repetir o do editor), ex: webhook.seudominio.com.br"
APP_SECRETS="N8N_ENCRYPTION_KEY:hex16;N8N_RUNNERS_AUTH_TOKEN:hex32"
APP_INPUTS=""
APP_NEEDS_POSTGRES="true"
APP_NEEDS_REDIS="true"
APP_SUMMARY_LINES="Editor: https://__APP_DOMAIN__;Webhook: https://__WEBHOOK_DOMAIN__;Runners externos habilitados;Banco: __POSTGRES_DATABASE__ (no PostgreSQL padrão)"
