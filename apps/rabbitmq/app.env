APP_SLUG="rabbitmq"
APP_LABEL="RabbitMQ"
APP_DESCRIPTION="Broker de filas AMQP com painel de administração web."
APP_CATEGORY="infra"
APP_IMAGE_REPO="rabbitmq"
APP_TESTED_TAGS="3.13-management-alpine"
APP_DOMAINS="APP_DOMAIN:Domínio do painel de administração, ex: rabbitmq.seudominio.com.br"
APP_SECRETS="RABBITMQ_DEFAULT_PASS:hex16"
APP_INPUTS="RABBITMQ_DEFAULT_USER:Usuário admin do RabbitMQ:admin"
APP_NEEDS_POSTGRES="false"
APP_NEEDS_REDIS="false"
APP_SUMMARY_LINES="Painel: https://__APP_DOMAIN__;AMQP interno: __STACK_NAME___rabbitmq:5672;Usuário: __RABBITMQ_DEFAULT_USER__;Senha: __RABBITMQ_DEFAULT_PASS__"
