APP_INPUTS=""
APP_NEEDS_POSTGRES="true"
APP_NEEDS_REDIS="false"
APP_SUMMARY_LINES="Builder: https://__APP_DOMAIN__;Viewer: https://__VIEWER_DOMAIN__;Banco: __POSTGRES_DATABASE__ (no PostgreSQL padrão);Crie a conta admin no primeiro acesso do builder"
