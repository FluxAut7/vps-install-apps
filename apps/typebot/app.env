APP_SLUG="typebot"
APP_LABEL="Typebot"
APP_DESCRIPTION="Construtor de chatbots conversacionais (builder + viewer)."
APP_CATEGORY="chat"
APP_IMAGE_REPO="baptistearno/typebot-builder"
APP_TESTED_TAGS="latest"
APP_DOMAINS="APP_DOMAIN:Domínio do builder (editor), ex: typebot.seudominio.com.br;VIEWER_DOMAIN:Domínio do viewer (bots publicados), ex: bot.seudominio.com.br"
